"hopper_shock_F_uvspec_sport": {
    "information":{
        "authors":"UVSpec",
        "name":"UVSpec Sport Front Shocks",
        "value":2000,
    },
    "slotType" : "hopper_shock_F",
    "flexbodies": [
         ["mesh", "[group]:", "nonFlexMaterials"],
         ["hopper_shock_F", ["hopper_shock_F"]],
    ],
    "beams": [
          ["id1:", "id2:"],
          //--FRONT SHOCKS--
          {"beamPrecompression":1.0, "beamType":"|BOUNDED", "beamLongBound":1, "beamShortBound":1},
          {"beamDeform":35000,"beamStrength":250000},
          {"beamLimitSpring":0,"beamLimitDamp":0},
          {"beamSpring":0,"beamDamp":6000},
          //to link mount because higher node weight
          ["faxs1r","fsh1r", {"beamDampFast":5000,"beamDampRebound":6000,"beamDampReboundFast":4500,"beamDampVelocitySplit":0.1,"dampCutoffHz":500}],
          ["faxs1l","fsh1l", {"beamDampFast":5000,"beamDampRebound":6000,"beamDampReboundFast":4500,"beamDampVelocitySplit":0.1,"dampCutoffHz":500}],
          //bumpstops
          {"beamSpring":0,"beamDamp":0},
          {"beamLimitSpring":151000,"beamLimitDamp":10000},
          ["fax1r","f13rr", {"longBoundRange":0.05,"shortBoundRange":0.12,"boundZone":0.05,"beamLimitDampRebound":0,"dampCutoffHz":500}],
          ["fax1l","f13ll", {"longBoundRange":0.05,"shortBoundRange":0.12,"boundZone":0.05,"beamLimitDampRebound":0,"dampCutoffHz":500}],
          {"beamPrecompression":1, "beamType":"|NORMAL", "beamLongBound":1, "beamShortBound":1},
    ],
},
