"hopper_spring_F_uvspec_sport": {
    "information":{
        "authors":"UVSpec",
        "name":"UVSpec Sport Front Springs",
        "value":1000,
    },
    "slotType" : "hopper_spring_F",
    "flexbodies": [
         ["mesh", "[group]:", "nonFlexMaterials"],
         ["hopper_spring_F", ["hopper_spring_F"]],
    ],
    "beams": [
          ["id1:", "id2:"],
          //front springs
          {"beamPrecompression":1, "beamType":"|NORMAL"},
          {"beamDeform":35000,"beamStrength":250000},
          {"beamSpring":26000,"beamDamp":0},
          ["faxshl","fs1l", {"precompressionRange":-0.03,"soundFile":"event:>Vehicle>Suspension>pickup_01>spring_compress_01","colorFactor":0.5,"attackFactor":10,"volumeFactor":1.8,"decayFactor":10,"noiseFactor":0.01,"pitchFactor":0.2,"maxStress":400}],
          ["faxshr","fs1r", {"precompressionRange":-0.03,"soundFile":"event:>Vehicle>Suspension>pickup_01>spring_compress_01","colorFactor":0.5,"attackFactor":10,"volumeFactor":1.8,"decayFactor":10,"noiseFactor":0.01,"pitchFactor":0.2,"maxStress":400}],
          //spring extents
          {"beamPrecompression":1.0, "beamType":"|BOUNDED", "beamLongBound":1, "beamShortBound":1},
          {"beamSpring":0,"beamDamp":0},
          {"beamLimitSpring":101000,"beamLimitDamp":1000},
          ["fax1r","f13rr", {"longBoundRange":0.12,"shortBoundRange":0.15,"boundZone":0.1,"beamLimitDampRebound":0,"dampCutoffHz":500}],
          ["fax1l","f13ll", {"longBoundRange":0.12,"shortBoundRange":0.15,"boundZone":0.1,"beamLimitDampRebound":0,"dampCutoffHz":500}],
          {"beamPrecompression":1, "beamType":"|NORMAL", "beamLongBound":1.0, "beamShortBound":1.0},
    ],
},
