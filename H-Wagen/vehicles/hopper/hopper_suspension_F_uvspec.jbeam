{
"hopper_swaybar_F_uvspec_sport": {
    "information":{
        "authors":"UVSpec",
        "name":"UVSpec Sport Front Sway Bar",
        "value":1500,
    },
    "slotType" : "hopper_swaybar_F",
    "flexbodies": [
        ["mesh", "[group]:", "nonFlexMaterials"],
        ["hopper_swaybar_F", ["hopper_swaybar_F"]],
    ],
    "nodes": [
         ["id", "posX", "posY", "posZ"],
         //anti-roll
         {"nodeMaterial":"|NM_METAL"},
         {"frictionCoef":0.5},
         {"group":"hopper_swaybar_F"},
         {"selfCollision":false},
         {"collision":true},
         {"nodeWeight":2.5},
         //front anti-roll
         ["arbfr", -0.47, -1.24, 0.44],
         ["arbfl", 0.47, -1.24, 0.44],
         {"group":""},
    ],
    "torsionbars": [
        ["id1:", "id2:", "id3:", "id4:"],
        //23mm 2021
        //24mm 2396
        //25mm 2822
        //26mm 3301
        //27mm 3839
        //28mm 4440
        {"spring":3839, "damp":10, "deform":10000, "strength":9999999},
        ["arbfr", "f2rr", "f2ll", "arbfl"],
    ],
    "beams": [
          ["id1:", "id2:"],
          //--ANTI-ROLL--
          {"beamPrecompression":1, "beamType":"|NORMAL", "beamLongBound":1, "beamShortBound":1},
          {"beamSpring":2501000,"beamDamp":100},
          {"beamDeform":25000,"beamStrength":534000},
          //end links
          ["arbfr","faxt1r"],
          ["arbfl","faxt1l"],
          //rigids
          ["arbfr","f2rr"],
          ["arbfl","f2ll"],
          ["arbfr","f2ll"],
          ["arbfl","f2rr"],
          {"beamPrecompression":1, "beamType":"|NORMAL", "beamLongBound":1.0, "beamShortBound":1.0},
    ],
},
