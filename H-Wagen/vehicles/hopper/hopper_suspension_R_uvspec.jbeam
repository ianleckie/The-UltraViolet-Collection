{
"hopper_swaybar_R_uvspec_sport": {
    "information":{
        "authors":"UVSpec",
        "name":"UVSpec Sport Rear Sway Bar",
        "value":1500,
    },
    "slotType" : "hopper_swaybar_R",
    "flexbodies": [
        ["mesh", "[group]:", "nonFlexMaterials"],
        ["hopper_swaybar_R", ["hopper_swaybar_R"]],
    ],
    "nodes": [
         ["id", "posX", "posY", "posZ"],
         //anti-roll
         {"nodeMaterial":"|NM_METAL"},
         {"frictionCoef":0.5},
         {"group":"hopper_swaybar_R"},
         {"selfCollision":false},
         {"collision":true},
         {"nodeWeight":2.5},
         //rear anti-roll
         ["arbrr", -0.58, 1.12, 0.43],
         ["arbrl", 0.58, 1.12, 0.43],
         {"group":""},
    ],
    "torsionbars": [
        ["id1:", "id2:", "id3:", "id4:"],
        //12mm 673
        //13mm 927
        //14mm 1247
        //15mm 1643
        //16mm 2128
        {"spring":1247, "damp":10, "deform":10000, "strength":9999999},
        ["arbrr", "f7rr", "f7ll", "arbrl"],
    ],
    "beams": [
          ["id1:", "id2:"],
          //--ANTI-ROLL--
          {"beamPrecompression":1, "beamType":"|NORMAL", "beamLongBound":1, "beamShortBound":1},
          {"beamSpring":2501000,"beamDamp":100},
          {"beamDeform":25000,"beamStrength":534000},
          //end links
          ["arbrr","ax1r"],
          ["arbrl","ax1l"],
          //rigids
          ["arbrr","f7rr"],
          ["arbrl","f7ll"],
          ["arbrr","f7ll"],
          ["arbrl","f7rr"],
          {"beamPrecompression":1, "beamType":"|NORMAL", "beamLongBound":1.0, "beamShortBound":1.0},
    ],
},
