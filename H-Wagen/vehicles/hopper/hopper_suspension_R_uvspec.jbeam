          //rear springs
          {"beamPrecompression":1, "beamType":"|NORMAL"},
          {"beamDeform":35000,"beamStrength":250000},
          {"beamSpring":24000,"beamDamp":0},
          ["axsl","f8ll", {"precompressionRange":0.025,"soundFile":"event:>Vehicle>Suspension>pickup_01>spring_compress_01","colorFactor":0.5,"attackFactor":20,"volumeFactor":1.6,"decayFactor":13,"noiseFactor":0.01,"pitchFactor":0.2,"maxStress":400}],
          ["axsr","f8rr", {"precompressionRange":0.025,"soundFile":"event:>Vehicle>Suspension>pickup_01>spring_compress_01","colorFactor":0.5,"attackFactor":20,"volumeFactor":1.6,"decayFactor":13,"noiseFactor":0.01,"pitchFactor":0.2,"maxStress":400}],
          //spring extents
          {"beamPrecompression":1.0, "beamType":"|BOUNDED", "beamLongBound":1, "beamShortBound":1},
          {"beamSpring":0,"beamDamp":0},
          {"beamLimitSpring":101000,"beamLimitDamp":1000},
          ["ax1r","f8rr", {"longBoundRange":0.12,"shortBoundRange":0.15,"boundZone":0.1,"beamLimitDampRebound":0,"dampCutoffHz":500}],
          ["ax1l","f8ll", {"longBoundRange":0.12,"shortBoundRange":0.15,"boundZone":0.1,"beamLimitDampRebound":0,"dampCutoffHz":500}],
          {"beamPrecompression":1, "beamType":"|NORMAL", "beamLongBound":1.0, "beamShortBound":1.0},
    ],
},
